#!/usr/bin/env bash
set -euo pipefail

#
# fleet - Thin infrastructure for parallel Claude Code sessions
#
# Usage:
#   fleet spawn <name> [--from ref] [--prompt "..." | --prompt-file path]
#   fleet stop [names...]
#   fleet attach
#   fleet ls
#

# ── Project detection ────────────────────────────────────────────────

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
REPO_NAME="$(basename "$REPO_ROOT")"
FLEET_BASE="$(dirname "$REPO_ROOT")/${REPO_NAME}-fleet"
BRIDGE_DIR="${FLEET_BASE}/_bridge"
SESSION="fleet-${REPO_NAME}"

# Auto-detect install command
detect_install_cmd() {
  local dir="$1"
  local cmds=()
  [ -f "$dir/Gemfile" ] && cmds+=("bundle install --quiet 2>/dev/null")
  if [ -f "$dir/package-lock.json" ]; then cmds+=("npm install --silent 2>/dev/null")
  elif [ -f "$dir/yarn.lock" ]; then cmds+=("yarn install --silent 2>/dev/null")
  elif [ -f "$dir/pnpm-lock.yaml" ]; then cmds+=("pnpm install --silent 2>/dev/null")
  elif [ -f "$dir/bun.lockb" ]; then cmds+=("bun install 2>/dev/null")
  fi
  [ -f "$dir/requirements.txt" ] && cmds+=("pip install -q -r requirements.txt 2>/dev/null")
  if [ -f "$dir/pyproject.toml" ]; then
    if [ -f "$dir/uv.lock" ]; then cmds+=("uv sync --quiet 2>/dev/null")
    elif [ -f "$dir/poetry.lock" ]; then cmds+=("poetry install --quiet 2>/dev/null")
    fi
  fi
  [ -f "$dir/Cargo.toml" ] && cmds+=("cargo build --quiet 2>/dev/null")
  [ -f "$dir/go.mod" ] && cmds+=("go mod download 2>/dev/null")
  [ -f "$dir/mix.exs" ] && cmds+=("mix deps.get --quiet 2>/dev/null")
  [ ${#cmds[@]} -eq 0 ] && return
  local IFS=" && "; echo "${cmds[*]}"
}

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
DIM='\033[2m'
NC='\033[0m'

log()  { echo -e "${GREEN}[fleet]${NC} $*"; }
warn() { echo -e "${YELLOW}[fleet]${NC} $*"; }
err()  { echo -e "${RED}[fleet]${NC} $*" >&2; }

# ── Bridge setup ─────────────────────────────────────────────────────

init_bridge() {
  mkdir -p "$BRIDGE_DIR"/{status,log,messages,discoveries}
}

# ── Worker protocol ──────────────────────────────────────────────────

PROTOCOL_FILE="${FLEET_SKILL_DIR:-$HOME/.claude/skills/fleet}/WORKER_PROTOCOL.md"

generate_worker_prompt() {
  local session_name="$1"
  local task_prompt="$2"

  if [ ! -f "$PROTOCOL_FILE" ]; then
    err "Worker protocol not found at $PROTOCOL_FILE. Run install.sh."
    exit 1
  fi

  local protocol
  protocol=$(cat "$PROTOCOL_FILE")
  protocol="${protocol//BRIDGE_DIR/$BRIDGE_DIR}"
  protocol="${protocol//SESSION_NAME/$session_name}"

  printf '%s\n\n---\n\n%s' "$task_prompt" "$protocol"
}

# ── spawn ────────────────────────────────────────────────────────────

cmd_spawn() {
  local name="" from_ref="main" prompt="" prompt_file="" no_install=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --from)         from_ref="$2"; shift 2 ;;
      --prompt)       prompt="$2"; shift 2 ;;
      --prompt-file)  prompt_file="$2"; shift 2 ;;
      --no-install)   no_install=true; shift ;;
      -h|--help)      usage ;;
      *)              name="$1"; shift ;;
    esac
  done

  if [ -z "$name" ]; then
    err "Usage: fleet spawn <name> [--from <ref>] [--prompt \"...\"]"
    exit 1
  fi

  # Read prompt from file if provided
  if [ -n "$prompt_file" ] && [ -f "$prompt_file" ]; then
    prompt=$(cat "$prompt_file")
  fi

  if [ -z "$prompt" ]; then
    prompt="You are working on: ${name}. Read CLAUDE.md for project conventions if it exists."
  fi

  init_bridge

  local worktree_dir="${FLEET_BASE}/${name}"
  local branch="fleet/${name}"

  # Create worktree
  mkdir -p "$FLEET_BASE"
  if [ -d "$worktree_dir" ]; then
    warn "Worktree exists, reusing"
  elif git -C "$REPO_ROOT" show-ref --verify --quiet "refs/heads/${branch}" 2>/dev/null; then
    git -C "$REPO_ROOT" worktree add "$worktree_dir" "$branch"
  else
    git -C "$REPO_ROOT" worktree add -b "$branch" "$worktree_dir" "$from_ref"
  fi

  # Generate full prompt (task + protocol)
  local full_prompt
  full_prompt=$(generate_worker_prompt "$name" "$prompt")

  local system_prompt_file="${BRIDGE_DIR}/worker-prompts/${name}.md"
  mkdir -p "${BRIDGE_DIR}/worker-prompts"
  echo "$full_prompt" > "$system_prompt_file"

  # Initialize status
  local now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  cat > "$BRIDGE_DIR/status/${name}.json" <<EOF
{"session":"${name}","phase":"starting","summary":"Session initializing","files_changed":[],"needs_human":false,"blocked_reason":null,"ci_status":null,"started_at":"${now}","updated_at":"${now}"}
EOF
  echo "{\"ts\":\"${now}\",\"event\":\"started\",\"detail\":\"Session created\"}" > "$BRIDGE_DIR/log/${name}.jsonl"

  # Create tmux pane
  if tmux has-session -t "$SESSION" 2>/dev/null; then
    tmux split-pane -t "$SESSION" -c "$worktree_dir"
    tmux select-layout -t "$SESSION" tiled
  else
    tmux new-session -d -s "$SESSION" -c "$worktree_dir" -x "$(tput cols)" -y "$(tput lines)"
    tmux set-option -t "$SESSION" remain-on-exit off
  fi

  # Start Claude
  local install_cmd=""
  if ! $no_install; then
    install_cmd=$(detect_install_cmd "$REPO_ROOT")
    [ -n "$install_cmd" ] && install_cmd="${install_cmd} && "
  fi

  tmux send-keys -t "$SESSION" "${install_cmd}claude --append-system-prompt \"\$(cat '${system_prompt_file}')\" --permission-mode acceptEdits" Enter
  tmux select-layout -t "$SESSION" tiled

  # Output JSON for the bridge to parse
  echo "{\"name\":\"${name}\",\"branch\":\"${branch}\",\"worktree\":\"${worktree_dir}\",\"bridge\":\"${BRIDGE_DIR}\"}"
}

# ── stop ─────────────────────────────────────────────────────────────

cmd_stop() {
  local targets=("$@")

  if [ ${#targets[@]} -eq 0 ]; then
    log "Tearing down all fleet worktrees..."
    tmux kill-session -t "$SESSION" 2>/dev/null && log "Killed tmux session" || true

    if [ -d "$FLEET_BASE" ]; then
      for dir in "$FLEET_BASE"/*/; do
        [ -d "$dir" ] || continue
        local name=$(basename "$dir")
        [ "$name" = "_bridge" ] && continue
        rm -f "${dir}/.fleet-prompt"
        git -C "$REPO_ROOT" worktree remove --force "$dir" 2>/dev/null && log "Removed $name" || warn "Could not remove $name"
      done
      git -C "$REPO_ROOT" branch --list 'fleet/*' | while read -r branch; do
        branch=$(echo "$branch" | tr -d ' *')
        git -C "$REPO_ROOT" branch -D "$branch" 2>/dev/null && log "Deleted branch $branch" || true
      done
    fi
    git -C "$REPO_ROOT" worktree prune
    log "Fleet stopped. Bridge data preserved at ${BRIDGE_DIR}"
  else
    for target in "${targets[@]}"; do
      local dir="${FLEET_BASE}/${target}"
      [ -d "$dir" ] || dir="${FLEET_BASE}/issue-${target}"
      if [ -d "$dir" ]; then
        local name=$(basename "$dir")
        rm -f "${dir}/.fleet-prompt"
        git -C "$REPO_ROOT" worktree remove --force "$dir" 2>/dev/null && log "Removed ${name}" || warn "Could not remove ${name}"
        git -C "$REPO_ROOT" branch -D "fleet/${name}" 2>/dev/null || true
      else
        warn "No worktree found for '${target}'"
      fi
    done
    git -C "$REPO_ROOT" worktree prune
  fi
}

# ── ls ───────────────────────────────────────────────────────────────

cmd_ls() {
  if [ ! -d "$FLEET_BASE" ]; then
    echo "[]"
    return
  fi

  # Output JSON array for Claude to parse
  echo "["
  local first=true
  for dir in "$FLEET_BASE"/*/; do
    [ -d "$dir" ] || continue
    local name=$(basename "$dir")
    [ "$name" = "_bridge" ] && continue

    local status_file="${BRIDGE_DIR}/status/${name}.json"
    local status="{}"
    [ -f "$status_file" ] && status=$(cat "$status_file")

    local branch
    branch=$(git -C "$dir" branch --show-current 2>/dev/null || echo "unknown")

    $first || echo ","
    first=false
    echo "  {\"name\":\"${name}\",\"branch\":\"${branch}\",\"worktree\":\"${dir}\",\"status\":${status}}"
  done
  echo "]"
}

# ── attach ───────────────────────────────────────────────────────────

cmd_attach() {
  if tmux has-session -t "$SESSION" 2>/dev/null; then
    tmux attach -t "$SESSION"
  else
    err "No fleet session. Spawn one first: fleet spawn <name>"
    exit 1
  fi
}

# ── info ─────────────────────────────────────────────────────────────

cmd_info() {
  cat <<EOF
{"repo":"${REPO_NAME}","repo_root":"${REPO_ROOT}","fleet_base":"${FLEET_BASE}","bridge":"${BRIDGE_DIR}","tmux_session":"${SESSION}"}
EOF
}

# ── main ─────────────────────────────────────────────────────────────

usage() {
  sed -n '3,10p' "$0" | sed 's/^# \?//'
  exit 0
}

case "${1:-}" in
  spawn)   shift; cmd_spawn "$@" ;;
  stop)    shift; cmd_stop "$@" ;;
  attach)  cmd_attach ;;
  ls)      cmd_ls ;;
  info)    cmd_info ;;
  -h|--help|help|"") usage ;;
  *)       err "Unknown command: $1"; usage ;;
esac
