#!/usr/bin/env bash
set -euo pipefail

# fleet - Thin infrastructure for parallel Claude Code sessions
#
# Usage:
#   fleet spawn <name> [--from ref] [--prompt "..." | --prompt-file path]
#   fleet stop [names...]   |  fleet attach  |  fleet detach  |  fleet ls
#   fleet telegram setup|send|test  |  fleet info

# ── Project detection ────────────────────────────────────────────────
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
REPO_NAME="$(basename "$REPO_ROOT")"
FLEET_BASE="$(dirname "$REPO_ROOT")/${REPO_NAME}-fleet"
BRIDGE_DIR="${FLEET_BASE}/_bridge"
SESSION="fleet-${REPO_NAME}"

detect_install_cmd() {
  local dir="$1" cmds=()
  [ -f "$dir/Gemfile" ] && cmds+=("bundle install --quiet 2>/dev/null")
  if [ -f "$dir/package-lock.json" ]; then cmds+=("npm install --silent 2>/dev/null")
  elif [ -f "$dir/yarn.lock" ]; then cmds+=("yarn install --silent 2>/dev/null")
  elif [ -f "$dir/pnpm-lock.yaml" ]; then cmds+=("pnpm install --silent 2>/dev/null")
  elif [ -f "$dir/bun.lockb" ]; then cmds+=("bun install 2>/dev/null")
  fi
  [ -f "$dir/requirements.txt" ] && cmds+=("pip install -q -r requirements.txt 2>/dev/null")
  if [ -f "$dir/pyproject.toml" ]; then
    if [ -f "$dir/uv.lock" ]; then cmds+=("uv sync --quiet 2>/dev/null")
    elif [ -f "$dir/poetry.lock" ]; then cmds+=("poetry install --quiet 2>/dev/null")
    fi
  fi
  [ -f "$dir/Cargo.toml" ] && cmds+=("cargo build --quiet 2>/dev/null")
  [ -f "$dir/go.mod" ] && cmds+=("go mod download 2>/dev/null")
  [ -f "$dir/mix.exs" ] && cmds+=("mix deps.get --quiet 2>/dev/null")
  [ ${#cmds[@]} -eq 0 ] && return
  local IFS=" && "; echo "${cmds[*]}"
}

GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RED='\033[0;31m'; NC='\033[0m'
log()  { echo -e "${GREEN}[fleet]${NC} $*"; }
warn() { echo -e "${YELLOW}[fleet]${NC} $*"; }
err()  { echo -e "${RED}[fleet]${NC} $*" >&2; }

init_bridge() { mkdir -p "$BRIDGE_DIR"/{status,log,messages,discoveries,worker-prompts} "$HOME/.fleet/directors"; }

# ── Worker protocol ──────────────────────────────────────────────────
PROTOCOL_FILE="${FLEET_SKILL_DIR:-$HOME/.claude/skills/fleet}/WORKER_PROTOCOL.md"

generate_worker_protocol() {
  local session_name="$1"
  [ ! -f "$PROTOCOL_FILE" ] && { err "Worker protocol not found at $PROTOCOL_FILE. Run install.sh."; exit 1; }
  local protocol
  protocol=$(cat "$PROTOCOL_FILE")
  protocol="${protocol//BRIDGE_DIR/$BRIDGE_DIR}"
  protocol="${protocol//SESSION_NAME/$session_name}"
  printf '%s' "$protocol"
}

# ── spawn ────────────────────────────────────────────────────────────
cmd_spawn() {
  local name="" from_ref="main" prompt="" prompt_file="" no_install=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --from)        from_ref="$2"; shift 2 ;;
      --prompt)      prompt="$2"; shift 2 ;;
      --prompt-file) prompt_file="$2"; shift 2 ;;
      --no-install)  no_install=true; shift ;;
      -h|--help)     usage ;;
      *)             name="$1"; shift ;;
    esac
  done
  [ -z "$name" ] && { err "Usage: fleet spawn <name> [--from <ref>] [--prompt \"...\"]"; exit 1; }
  [ -n "$prompt_file" ] && [ -f "$prompt_file" ] && prompt=$(cat "$prompt_file")
  [ -z "$prompt" ] && prompt="You are working on: ${name}. Read CLAUDE.md for project conventions if it exists."

  init_bridge
  local worktree_dir="${FLEET_BASE}/${name}" branch="fleet/${name}"
  mkdir -p "$FLEET_BASE"
  if [ -d "$worktree_dir" ]; then warn "Worktree exists, reusing"
  elif git -C "$REPO_ROOT" show-ref --verify --quiet "refs/heads/${branch}" 2>/dev/null; then
    git -C "$REPO_ROOT" worktree add "$worktree_dir" "$branch"
  else git -C "$REPO_ROOT" worktree add -b "$branch" "$worktree_dir" "$from_ref"
  fi

  local worker_protocol now
  worker_protocol=$(generate_worker_protocol "$name")
  echo "$worker_protocol" > "${BRIDGE_DIR}/worker-prompts/${name}-protocol.md"
  echo "$prompt" > "${BRIDGE_DIR}/worker-prompts/${name}-task.md"
  now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  echo "{\"session\":\"${name}\",\"phase\":\"starting\",\"summary\":\"Session initializing\",\"files_changed\":[],\"needs_human\":false,\"blocked_reason\":null,\"escalation\":null,\"ci_status\":null,\"started_at\":\"${now}\",\"updated_at\":\"${now}\"}" > "$BRIDGE_DIR/status/${name}.json"
  echo "{\"ts\":\"${now}\",\"event\":\"started\",\"detail\":\"Session created\"}" > "$BRIDGE_DIR/log/${name}.jsonl"

  if tmux has-session -t "$SESSION" 2>/dev/null; then
    tmux split-pane -t "$SESSION" -c "$worktree_dir"
  else
    tmux new-session -d -s "$SESSION" -c "$worktree_dir" -x "$(tput cols)" -y "$(tput lines)"
    tmux set-option -t "$SESSION" remain-on-exit off
  fi

  # Write a launcher script that tmux executes
  local launcher="${BRIDGE_DIR}/worker-prompts/${name}-launch.sh"
  {
    echo "#!/usr/bin/env bash"
    if ! $no_install; then
      local ic=$(detect_install_cmd "$REPO_ROOT")
      [ -n "$ic" ] && echo "$ic"
    fi
    echo "exec claude --append-system-prompt \"\$(cat '${BRIDGE_DIR}/worker-prompts/${name}-protocol.md')\" --permission-mode acceptEdits -p \"\$(cat '${BRIDGE_DIR}/worker-prompts/${name}-task.md')\""
  } > "$launcher"
  chmod +x "$launcher"
  tmux send-keys -t "$SESSION" "bash '${launcher}'" Enter
  tmux select-layout -t "$SESSION" tiled
  echo "{\"name\":\"${name}\",\"branch\":\"${branch}\",\"worktree\":\"${worktree_dir}\",\"bridge\":\"${BRIDGE_DIR}\"}"
}

# ── stop ─────────────────────────────────────────────────────────────
cmd_stop() {
  local targets=("$@")
  if [ ${#targets[@]} -eq 0 ]; then
    log "Tearing down all fleet worktrees..."
    tmux kill-session -t "$SESSION" 2>/dev/null && log "Killed tmux session" || true
    if [ -d "$FLEET_BASE" ]; then
      for dir in "$FLEET_BASE"/*/; do
        [ -d "$dir" ] || continue
        local n=$(basename "$dir"); [ "$n" = "_bridge" ] && continue
        git -C "$REPO_ROOT" worktree remove --force "$dir" 2>/dev/null && log "Removed $n" || warn "Could not remove $n"
      done
      git -C "$REPO_ROOT" branch --list 'fleet/*' | while read -r b; do
        git -C "$REPO_ROOT" branch -D "$(echo "$b" | tr -d ' *')" 2>/dev/null || true
      done
    fi
    git -C "$REPO_ROOT" worktree prune
    log "Fleet stopped. Bridge data preserved at ${BRIDGE_DIR}"
  else
    for target in "${targets[@]}"; do
      local dir="${FLEET_BASE}/${target}"
      [ -d "$dir" ] || dir="${FLEET_BASE}/issue-${target}"
      if [ -d "$dir" ]; then
        local n=$(basename "$dir")
        git -C "$REPO_ROOT" worktree remove --force "$dir" 2>/dev/null && log "Removed $n" || warn "Could not remove $n"
        git -C "$REPO_ROOT" branch -D "fleet/$n" 2>/dev/null || true
      else warn "No worktree found for '${target}'"
      fi
    done
    git -C "$REPO_ROOT" worktree prune
  fi
}

# ── ls ───────────────────────────────────────────────────────────────
cmd_ls() {
  [ ! -d "$FLEET_BASE" ] && { echo "[]"; return; }
  echo "["
  local first=true
  for dir in "$FLEET_BASE"/*/; do
    [ -d "$dir" ] || continue
    local n=$(basename "$dir"); [ "$n" = "_bridge" ] && continue
    local status="{}"; [ -f "${BRIDGE_DIR}/status/${n}.json" ] && status=$(cat "${BRIDGE_DIR}/status/${n}.json")
    local branch; branch=$(git -C "$dir" branch --show-current 2>/dev/null || echo "unknown")
    $first || echo ","; first=false
    echo "  {\"name\":\"${n}\",\"branch\":\"${branch}\",\"worktree\":\"${dir}\",\"status\":${status}}"
  done
  echo "]"
}

# ── resume ───────────────────────────────────────────────────────────
cmd_resume() {
  local name="${1:-}" prompt="${2:-}"
  [ -z "$name" ] && { err "Usage: fleet resume <name> [\"prompt\"]"; exit 1; }
  local worktree_dir="${FLEET_BASE}/${name}"
  [ -d "$worktree_dir" ] || { err "No worktree for '${name}'"; exit 1; }
  tmux has-session -t "$SESSION" 2>/dev/null || { err "No fleet tmux session"; exit 1; }
  # Find the pane running in this worker's worktree
  local target_pane=""
  while IFS= read -r line; do
    local pane_id pane_path
    pane_id=$(echo "$line" | cut -d: -f1)
    pane_path=$(echo "$line" | cut -d: -f2-)
    if [[ "$pane_path" == *"${name}"* ]]; then
      target_pane="$pane_id"
      break
    fi
  done < <(tmux list-panes -s -t "$SESSION" -F '#{pane_id}:#{pane_current_path}')
  [ -z "$target_pane" ] && { err "Could not find pane for '${name}'"; exit 1; }
  if [ -n "$prompt" ]; then
    tmux send-keys -t "$target_pane" "$prompt" Enter
  fi
  log "Resumed ${name}"
}

# ── detach / attach ──────────────────────────────────────────────────
cmd_detach() {
  [ ! -d "$BRIDGE_DIR" ] && { err "No active fleet. Spawn workers first."; exit 1; }
  local watcher_path="${FLEET_INSTALL_DIR:-$HOME/.local/bin}/fleet-watcher"
  [ ! -f "$watcher_path" ] && watcher_path="$(dirname "$0")/fleet-watcher"
  [ ! -f "$watcher_path" ] && { err "fleet-watcher not found. Run install.sh."; exit 1; }
  "$watcher_path" "$BRIDGE_DIR" &
  local watcher_pid=$! now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  echo "{\"mode\":\"detached\",\"detached_at\":\"${now}\",\"watcher_pid\":${watcher_pid}}" > "${BRIDGE_DIR}/state.json"
  echo -e "# Fleet Briefing\n\nDetached at ${now}\n" > "${BRIDGE_DIR}/briefing.md"
  log "Fleet detached. Watcher running (PID ${watcher_pid})."
  [ -f "${FLEET_CONFIG_DIR:-$HOME/.fleet}/telegram.json" ] && log "Telegram notifications active." || warn "No Telegram configured. Run 'fleet telegram setup' for notifications."
  log "Run 'fleet attach' to reattach with a briefing."
}

cmd_attach() {
  if [ -f "${BRIDGE_DIR}/state.json" ] 2>/dev/null; then
    local mode watcher_pid
    mode=$(jq -r '.mode // empty' "${BRIDGE_DIR}/state.json" 2>/dev/null)
    watcher_pid=$(jq -r '.watcher_pid // empty' "${BRIDGE_DIR}/state.json" 2>/dev/null)
    if [ "$mode" = "detached" ] && [ -n "$watcher_pid" ]; then
      kill "$watcher_pid" 2>/dev/null || true
      echo "{\"mode\":\"live\",\"reattached_at\":\"$(date -u +"%Y-%m-%dT%H:%M:%SZ")\",\"watcher_pid\":null}" > "${BRIDGE_DIR}/state.json"
      log "Watcher stopped. Reattached."
      [ -f "${BRIDGE_DIR}/briefing.md" ] && { echo ""; cat "${BRIDGE_DIR}/briefing.md"; echo ""; }
    fi
  fi
  if tmux has-session -t "$SESSION" 2>/dev/null; then tmux attach -t "$SESSION"
  else err "No fleet session. Spawn one first: fleet spawn <name>"; exit 1; fi
}

cmd_info() { echo "{\"repo\":\"${REPO_NAME}\",\"repo_root\":\"${REPO_ROOT}\",\"fleet_base\":\"${FLEET_BASE}\",\"bridge\":\"${BRIDGE_DIR}\",\"tmux_session\":\"${SESSION}\"}"; }

# ── telegram ────────────────────────────────────────────────────────
FLEET_CONFIG_DIR="${HOME}/.fleet"
TELEGRAM_CONFIG="${FLEET_CONFIG_DIR}/telegram.json"

telegram_setup() {
  mkdir -p "$FLEET_CONFIG_DIR"
  log "Telegram setup: Create a bot via @BotFather on Telegram and copy the token."
  read -rp "Bot token: " bot_token
  [ -z "$bot_token" ] && { err "Token cannot be empty."; exit 1; }
  log "Now send any message to your bot in Telegram, then press Enter here."
  read -r
  local chat_id attempt
  for attempt in 1 2 3; do
    chat_id=$(curl -s "https://api.telegram.org/bot${bot_token}/getUpdates" | jq -r '.result[-1].message.chat.id // empty')
    [ -n "$chat_id" ] && break
    [ "$attempt" -lt 3 ] && { log "Waiting for message to arrive..."; sleep 2; }
  done
  [ -z "$chat_id" ] && { err "Could not detect chat_id. Make sure you sent a message to the bot."; exit 1; }
  echo "{\"bot_token\":\"${bot_token}\",\"chat_id\":\"${chat_id}\"}" > "$TELEGRAM_CONFIG"
  curl -s -X POST "https://api.telegram.org/bot${bot_token}/sendMessage" \
    -d chat_id="$chat_id" -d text="Fleet connected!" -d parse_mode=Markdown > /dev/null
  log "Telegram configured! Config saved to ${TELEGRAM_CONFIG}"
}

telegram_send() {
  [ ! -f "$TELEGRAM_CONFIG" ] && { err "Telegram not configured. Run: fleet telegram setup"; exit 1; }
  local token chat_id text="${1:-}"
  token=$(jq -r '.bot_token' "$TELEGRAM_CONFIG")
  chat_id=$(jq -r '.chat_id' "$TELEGRAM_CONFIG")
  [ -z "$text" ] && { err "Usage: fleet telegram send \"message\""; exit 1; }
  curl -s -X POST "https://api.telegram.org/bot${token}/sendMessage" \
    -d chat_id="$chat_id" -d text="$text" -d parse_mode=Markdown > /dev/null
}

cmd_telegram() {
  case "${1:-}" in
    setup) telegram_setup ;;
    send)  shift; telegram_send "$*" ;;
    test)  telegram_send "Fleet test message" && log "Test message sent!" ;;
    *)     err "Usage: fleet telegram setup|send|test"; exit 1 ;;
  esac
}

usage() { sed -n '3,8p' "$0" | sed 's/^# \?//'; exit 0; }

case "${1:-}" in
  spawn)    shift; cmd_spawn "$@" ;;
  stop)     shift; cmd_stop "$@" ;;
  resume)   shift; cmd_resume "$1" "${*:2}" ;;
  attach)   cmd_attach ;;
  detach)   cmd_detach ;;
  ls)       cmd_ls ;;
  info)     cmd_info ;;
  telegram) shift; cmd_telegram "$@" ;;
  -h|--help|help|"") usage ;;
  *)        err "Unknown command: $1"; usage ;;
esac
