#!/usr/bin/env bash
set -euo pipefail

# fleet-watcher - Background process for detached fleet mode
# Monitors worker status, sends Telegram notifications, polls for inbound messages.
# Started by `fleet detach`, killed by `fleet attach`.

BRIDGE_DIR="${1:?Usage: fleet-watcher <bridge_dir>}"
FLEET_BASE="$(dirname "$BRIDGE_DIR")"
FLEET_CMD="${FLEET_INSTALL_DIR:-$HOME/.local/bin}/fleet"
FLEET_CONFIG_DIR="${HOME}/.fleet"
TELEGRAM_CONFIG="${FLEET_CONFIG_DIR}/telegram.json"
POLL_INTERVAL="${FLEET_POLL_INTERVAL:-10}"
TELEGRAM_OFFSET_FILE="${BRIDGE_DIR}/.telegram_offset"
MTIME_DIR="${BRIDGE_DIR}/.watcher_mtimes"

mkdir -p "$MTIME_DIR" "${BRIDGE_DIR}/log"

get_mtime() {
  if [[ "$(uname)" == "Darwin" ]]; then
    stat -f %m "$1" 2>/dev/null || echo 0
  else
    stat -c %Y "$1" 2>/dev/null || echo 0
  fi
}

tg_configured() { [ -f "$TELEGRAM_CONFIG" ]; }

tg_send() {
  tg_configured || return 0
  local token chat_id
  token=$(jq -r .bot_token "$TELEGRAM_CONFIG")
  chat_id=$(jq -r .chat_id "$TELEGRAM_CONFIG")
  curl -s -X POST "https://api.telegram.org/bot${token}/sendMessage" \
    -d chat_id="$chat_id" -d text="$1" -d parse_mode=Markdown > /dev/null 2>&1 || true
}

tg_poll() {
  tg_configured || return 0
  local token chat_id offset response
  token=$(jq -r .bot_token "$TELEGRAM_CONFIG")
  chat_id=$(jq -r .chat_id "$TELEGRAM_CONFIG")
  offset=0
  [ -f "$TELEGRAM_OFFSET_FILE" ] && offset=$(cat "$TELEGRAM_OFFSET_FILE")

  response=$(curl -s "https://api.telegram.org/bot${token}/getUpdates?offset=${offset}&timeout=0" 2>/dev/null) || return 0

  local count
  count=$(echo "$response" | jq '.result | length' 2>/dev/null) || return 0
  [ "$count" -gt 0 ] || return 0

  local i update_id text ts
  for ((i = 0; i < count; i++)); do
    update_id=$(echo "$response" | jq ".result[$i].update_id")
    text=$(echo "$response" | jq -r ".result[$i].message.text // empty")
    [ -n "$text" ] || continue

    # Validate sender matches configured chat_id
    local msg_chat_id
    msg_chat_id=$(echo "$response" | jq -r ".result[$i].message.chat.id // empty")
    [ "$msg_chat_id" = "$chat_id" ] || continue

    echo $((update_id + 1)) > "$TELEGRAM_OFFSET_FILE"
    ts=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    {
      echo ""
      echo "### Director message ($ts)"
      echo "$text"
    } >> "${BRIDGE_DIR}/briefing.md"
    printf '{"ts":"%s","event":"telegram_inbound","text":"%s"}\n' \
      "$ts" "$(echo "$text" | sed 's/"/\\"/g')" >> "${BRIDGE_DIR}/log/_watcher.jsonl"
    # Try as a simple command first, then use Claude to interpret
    if ! handle_command "$text" "$ts"; then
      handle_with_bridge "$text" "$ts"
    fi
  done
}

validate_name() {
  local name="$1"
  [ -z "$name" ] && return 1
  [[ "$name" =~ ^[a-zA-Z0-9][a-zA-Z0-9._-]*$ ]] || return 1
}

# ── Command handling ─────────────────────────────────────────────────
handle_command() {
  local text="$1" ts="$2"
  local lower
  lower=$(echo "$text" | tr '[:upper:]' '[:lower:]')

  # spawn <name> <prompt...>
  if [[ "$lower" =~ ^spawn[[:space:]] ]]; then
    local rest="${text#*[[:space:]]}"
    local name="${rest%%[[:space:]]*}"
    local prompt="${rest#*[[:space:]]}"
    [ "$prompt" = "$name" ] && prompt="You are working on: ${name}. Read CLAUDE.md for project conventions if it exists."
    if ! validate_name "$name"; then
      tg_send "Invalid worker name: ${name}"
      return 0
    fi
    tg_send "Spawning *${name}*..."
    if "$FLEET_CMD" spawn "$name" --prompt "$prompt" > /dev/null 2>&1; then
      tg_send "*${name}* spawned and working."
      (echo "- **Spawned ${name}** via Telegram ($ts)" >> "${BRIDGE_DIR}/briefing.md")
    else
      tg_send "Failed to spawn *${name}*. Check the terminal."
      (echo "- **Failed to spawn ${name}** via Telegram ($ts)" >> "${BRIDGE_DIR}/briefing.md")
    fi
    return 0
  fi

  # resume <name> <prompt>
  if [[ "$lower" =~ ^resume[[:space:]] ]]; then
    local rest="${text#*[[:space:]]}"
    local name="${rest%%[[:space:]]*}"
    local prompt="${rest#*[[:space:]]}"
    [ "$prompt" = "$name" ] && prompt=""
    if ! validate_name "$name"; then
      tg_send "Invalid worker name: ${name}"
      return 0
    fi
    tg_send "Resuming *${name}*..."
    if "$FLEET_CMD" resume "$name" "$prompt" > /dev/null 2>&1; then
      tg_send "*${name}* resumed."
      (echo "- **Resumed ${name}** via Telegram ($ts)" >> "${BRIDGE_DIR}/briefing.md")
    else
      tg_send "Could not resume *${name}*."
    fi
    return 0
  fi

  # stop <name>
  if [[ "$lower" =~ ^stop[[:space:]] ]]; then
    local name="${text#*[[:space:]]}"
    if ! validate_name "$name"; then
      tg_send "Invalid worker name: ${name}"
      return 0
    fi
    tg_send "Stopping *${name}*..."
    "$FLEET_CMD" stop "$name" > /dev/null 2>&1 && tg_send "*${name}* stopped." || tg_send "Could not stop *${name}*."
    (echo "- **Stopped ${name}** via Telegram ($ts)" >> "${BRIDGE_DIR}/briefing.md")
    return 0
  fi

  # status
  if [[ "$lower" =~ ^(status|sitrep|what.s.happening) ]]; then
    local msg="*Fleet status:*"$'\n'
    for sf in "${BRIDGE_DIR}"/status/*.json; do
      [ -f "$sf" ] || continue
      local n p s
      n=$(basename "$sf" .json)
      p=$(jq -r '.phase // "unknown"' "$sf" 2>/dev/null)
      s=$(jq -r '.summary // ""' "$sf" 2>/dev/null)
      msg+="- *${n}*: ${p} -- ${s}"$'\n'
    done
    [ "$msg" = "*Fleet status:*"$'\n' ] && msg="No active workers."
    tg_send "$msg"
    return 0
  fi

  return 1  # Not a command, route to worker
}

handle_with_bridge() {
  local text="$1" ts="$2"
  tg_send "Thinking..."

  # Build context: current fleet state
  local context="The director sent this message via Telegram while detached:\n\n\"${text}\"\n\n"
  context+="Current fleet state:\n"
  for sf in "${BRIDGE_DIR}"/status/*.json; do
    [ -f "$sf" ] || continue
    local n p s
    n=$(basename "$sf" .json)
    p=$(jq -r '.phase // "unknown"' "$sf" 2>/dev/null)
    s=$(jq -r '.summary // ""' "$sf" 2>/dev/null)
    context+="- ${n}: ${p} -- ${s}\n"
  done
  [ -f "${BRIDGE_DIR}/queue.json" ] && context+="\nQueue: $(cat "${BRIDGE_DIR}/queue.json")\n"

  # Find the repo root from the fleet base directory
  local repo_root=""
  for d in "${FLEET_BASE%%-fleet}" "${FLEET_BASE%-fleet}"; do
    [ -d "$d/.git" ] && { repo_root="$d"; break; }
  done
  [ -z "$repo_root" ] && repo_root="$(cd "$FLEET_BASE" && git rev-parse --show-toplevel 2>/dev/null || echo "$HOME")"

  local prompt
  prompt=$(cat <<PROMPT
You are the Fleet bridge handling a Telegram message from the director who is away from the terminal.

${context}

Bridge directory: ${BRIDGE_DIR}
Repo root: ${repo_root}

Your job:
1. Interpret what the director wants
2. Take action using the fleet CLI or by writing to bridge files
3. Respond with a SHORT message (1-3 sentences) that I will send back via Telegram

Available commands:
- fleet spawn <name> --prompt "..." (run from repo root -- starts a new worker)
- fleet resume <name> "prompt" (sends a prompt to an existing idle worker session)
- fleet stop <name>
- Write to _bridge/messages/{worker}.md to send instructions to a worker at its next checkpoint

Rules:
- If the director wants to start new work, use fleet spawn with a rich prompt
- If they're giving guidance to an existing worker, write to that worker's message file
- If the director is asking a question, answer it from the status files
- Be decisive. Do not ask clarifying questions -- make your best judgment
- Your LAST line of output will be sent to the director via Telegram. Make it informative and concise.
PROMPT
)

  local response
  response=$(cd "$repo_root" && claude --print --allowedTools 'Bash(*)' Read Edit Write Glob Grep -p "$prompt" 2>/dev/null | tail -5) || {
    tg_send "Could not process that. Try a direct command like: spawn <name> <task>"
    return 0
  }

  # Send the last meaningful line(s) back via Telegram
  local reply
  reply=$(echo "$response" | grep -v '^$' | tail -3)
  [ -n "$reply" ] && tg_send "$reply" || tg_send "Done."
  (echo "- **Bridge handled Telegram message** ($ts): ${text}" >> "${BRIDGE_DIR}/briefing.md")
}

check_status_changes() {
  for sf in "${BRIDGE_DIR}"/status/*.json; do
    [ -f "$sf" ] || continue
    local name mt saved_mt
    name=$(basename "$sf" .json)
    mt=$(get_mtime "$sf")
    saved_mt=0
    [ -f "${MTIME_DIR}/${name}" ] && saved_mt=$(cat "${MTIME_DIR}/${name}")
    [ "$mt" != "$saved_mt" ] || continue
    echo "$mt" > "${MTIME_DIR}/${name}"

    local phase summary needs_human ts
    phase=$(jq -r '.phase // "unknown"' "$sf" 2>/dev/null) || continue
    summary=$(jq -r '.summary // ""' "$sf" 2>/dev/null) || true
    needs_human=$(jq -r '.needs_human // false' "$sf" 2>/dev/null) || true
    ts=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

    case "$phase" in
      done)
        tg_send "*${name}* finished: ${summary}"
        (echo "- **${name}** finished ($ts): ${summary}" >> "${BRIDGE_DIR}/briefing.md")
        ;;
      blocked|failed)
        local decision recommendation stakes
        decision=$(jq -r '.escalation.decision // empty' "$sf" 2>/dev/null) || true
        recommendation=$(jq -r '.escalation.recommendation // empty' "$sf" 2>/dev/null) || true
        stakes=$(jq -r '.escalation.stakes // "unknown"' "$sf" 2>/dev/null) || true

        if [ -n "$decision" ]; then
          tg_send "*${name}* needs you (${stakes} stakes): ${decision} -- Recommendation: ${recommendation}"
        else
          tg_send "*${name}* is ${phase}: ${summary}"
        fi
        (echo "- **${name}** ${phase} ($ts): ${summary}" >> "${BRIDGE_DIR}/briefing.md")
        ;;
      *)
        (echo "- **${name}** ${phase} ($ts): ${summary}" >> "${BRIDGE_DIR}/briefing.md")
        ;;
    esac
    printf '{"ts":"%s","event":"status_change","worker":"%s","phase":"%s","summary":"%s"}\n' \
      "$ts" "$name" "$phase" "$(echo "$summary" | sed 's/"/\\"/g')" >> "${BRIDGE_DIR}/log/_watcher.jsonl"

  done
}

echo "{\"ts\":\"$(date -u +"%Y-%m-%dT%H:%M:%SZ")\",\"event\":\"watcher_started\",\"detail\":\"Polling every ${POLL_INTERVAL}s\"}" >> "${BRIDGE_DIR}/log/_watcher.jsonl"

reap_finished_workers() {
  local reap_after=300  # 5 minutes
  for sf in "${BRIDGE_DIR}"/status/*.json; do
    [ -f "$sf" ] || continue
    local name phase updated_at
    name=$(basename "$sf" .json)
    phase=$(jq -r '.phase // "unknown"' "$sf" 2>/dev/null) || continue
    [[ "$phase" != "done" && "$phase" != "failed" ]] && continue
    updated_at=$(jq -r '.updated_at // empty' "$sf" 2>/dev/null) || continue
    [ -z "$updated_at" ] && continue
    local updated_epoch now_epoch age
    if [[ "$(uname)" == "Darwin" ]]; then
      updated_epoch=$(date -jf "%Y-%m-%dT%H:%M:%SZ" "$updated_at" +%s 2>/dev/null) || continue
    else
      updated_epoch=$(date -d "$updated_at" +%s 2>/dev/null) || continue
    fi
    now_epoch=$(date +%s)
    age=$(( now_epoch - updated_epoch ))
    [ "$age" -lt "$reap_after" ] && continue
    # Worker has been done/failed for 5+ minutes -- clean up worktree only, keep branch
    local worktree_dir="${FLEET_BASE}/${name}"
    [ -d "$worktree_dir" ] && git -C "$(dirname "$FLEET_BASE")" worktree remove --force "$worktree_dir" 2>/dev/null || true
    git -C "$(dirname "$FLEET_BASE")" worktree prune 2>/dev/null || true
    rm -f "$sf" "${BRIDGE_DIR}/log/${name}.jsonl" "${MTIME_DIR}/${name}"
    printf '{"ts":"%s","event":"reaped","worker":"%s","phase":"%s","age_seconds":%d}\n' \
      "$(date -u +"%Y-%m-%dT%H:%M:%SZ")" "$name" "$phase" "$age" >> "${BRIDGE_DIR}/log/_watcher.jsonl"
  done
}

while true; do
  check_status_changes
  reap_finished_workers
  tg_poll
  sleep "$POLL_INTERVAL"
done
